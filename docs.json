{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "棒无の知识库",
  "description": "红温小丑：一个对小白友好的教程知识库，涵盖前后端、软件、环境、课程笔记与兴趣内容。",
  "logo": "/assets/joker.png",
  "favicon": "/assets/joker.png",
  "colors": {
    "primary": "#14b8a6",
    "light": "#99f6e4",
    "dark": "#0f766e"
  },
  "appearance": {
    "default": "system"
  },
  "search": {
    "prompt": "搜索教程、软件、命令和知识点..."
