{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "bangwu's Knowledge Base",
  "description": "A beginner-friendly tutorial knowledge base covering frontend, backend, tools, environment, and course notes.",
  "logo": "/assets/joker.png",
  "favicon": {
    "light": "/assets/joker.png",
    "dark": "/assets/joker.png"
  },
  "colors": {
    "primary": "#14b8a6",
    "light": "#99f6e4",
    "dark": "#0f766e"
