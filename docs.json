{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "棒无の知识库",
  "description": "红温小丑：一个对小白友好的教程知识库，涵盖前后端、软件、环境、课程笔记与兴趣内容。",
  "logo": "/assets/joker.png",
  "favicon": {
    "light": "/assets/joker.png",
    "dark": "/assets/joker.png"
  },
  "colors": {
    "primary": "#14b8a6",
    "light": "#99f6e4",
    "dark": "#0f766e"
  },
  "appearance": {
    "default": "system"
  },
  "metadata": {
    "timestamp": true
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:site_name": "棒无の知识库",
      "twitter:card": "summary_large_image"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    },
    "latex": true
  },
  "navbar": {
    "links": [
      {
        "label": "博客",
        "href": "https://bangwu.me"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/markbang"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/markbang",
      "x-twitter": "https://x.com/bangwu_",
      "website": "https://bangwu.me"
    }
  },
