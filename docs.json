    "indexing": "all",
    "metatags": {
      "og:site_name": "bangwu's Knowledge Base",
      "twitter:card": "summary_large_image"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    },
    "latex": true
  },
  "footer": {
    "socials": {
      "github": "https://github.com/markbang",
      "x-twitter": "https://x.com/bangwu_",
      "website": "https://bangwu.me"
    }
  },
